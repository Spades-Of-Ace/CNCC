---
import Footer from "../components/Footer.astro";
import MainLayout from "../layouts/MainLayout.astro";
import ruleBackground from "../assets/images/Rule background.png";

const rules = [
  "Each participant must be a Cambodian national.",
  "Participants earn points for each correct submission. Points are awarded based on the difficulty level of the challenges.",
  "Participants may choose freely which challenges to solve and in any order they prefer.",
  "Participants must compete fairly and ethically.",
  "Participants must not attack the competition infrastructure.",
  "Participants must not interfere with other teams' or participants' work.",
  "Sharing flags between teams is prohibited.",
  "All flags must be submitted through the official competition platform.",
  "Flags are usually in a specific format, announced prior to the competition day.",
  "Submitting fake, brute-forced, or guessed flags may result in penalties or disqualification.",
  "Automated scanning, brute-forcing, or DoS attacks against the competition servers are prohibited.",
  "Do not attempt to exploit platform vulnerabilities outside of the challenges.",
  "Any cheating, plagiarism, flag sharing, or other unsportsmanlike behavior will result in immediate disqualification.",
  "Organizers reserve the right to monitor all activity and enforce rules as needed.",
  "The Organizing Committee reserves the right to make all final decisions regarding this competition.",
];
---

<MainLayout>
  <main class="bg-[#f7fbff] text-[#07143a]">
    <section class="relative isolate overflow-hidden px-6 pb-24 pt-32 text-white sm:px-10 lg:px-16">
      <img
        src={ruleBackground.src}
        alt=""
        class="absolute inset-0 -z-20 h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-[#02091b]/86 via-[#02091b]/45 to-transparent"></div>

      <div class="mx-auto max-w-[1500px] py-16">
        <h1 class="text-5xl font-black uppercase leading-tight sm:text-6xl">
          Rules
        </h1>
        <p class="mt-5 text-xl font-black text-slate-100">
          Fair Play. Respect. Excellence.
        </p>
      </div>
    </section>

    <section class="px-6 py-20 sm:px-10 lg:px-16">
      <div class="mx-auto max-w-[1500px]">
        <div class="mb-10 text-center">
          <p class="text-sm font-black uppercase tracking-wide text-[#d97918]">
            Rules of the Game
          </p>
          <h2 class="mt-3 text-4xl font-black sm:text-5xl">
            Competition Guidelines
          </h2>
        </div>

        <ol class="grid gap-5 lg:grid-cols-2">
          {
            rules.map((rule, index) => (
              <li class="flex gap-5 rounded-xl border border-[#d9e6f7] bg-white p-5 shadow-[0_12px_34px_rgba(7,20,58,0.07)]">
                <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[#0f6bff]/10 text-sm font-black text-[#0b54c8]">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <p class="self-center text-sm font-semibold leading-7 text-slate-700">
                  {rule}
                </p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>
