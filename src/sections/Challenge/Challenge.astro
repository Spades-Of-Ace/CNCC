---
const challenges = [
  ["Reverse Engineering", "Analyze and understand programs and systems.", "code"],
  ["Cryptography", "Break codes and secure communications.", "lock"],
  ["Web Security", "Find and exploit web vulnerabilities.", "globe"],
  ["Forensics", "Investigate digital evidence and incidents.", "search"],
  ["Pwn", "Exploit systems and gain control.", "terminal"],
  ["Binary Exploitation", "Dive deep into binaries and memory.", "bug"],
];
---

<section
  id="challenge"
  class="bg-[#f7fbff] px-6 py-20 text-[#07143a] sm:px-10 lg:px-16"
>
  <div class="mx-auto max-w-[1500px]">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-black uppercase tracking-wide text-[#d97918]">
        Challenges
      </p>
      <h2 class="mt-3 text-4xl font-black leading-tight sm:text-5xl">
        6 Domains. 100+ Challenges.
      </h2>
      <p class="mt-3 text-base font-medium text-slate-600">
        Test your skills across a wide range of cybersecurity disciplines.
      </p>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
      {
        challenges.map(([title, description, icon]) => (
          <article class="rounded-lg border border-[#d9e6f7] bg-white p-5 text-center shadow-[0_12px_34px_rgba(7,20,58,0.07)]">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-lg bg-[#0b54c8] text-sky-200 shadow-[0_12px_24px_rgba(15,107,255,0.24)]">
              {
                icon === "code" && (
                  <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="m8 9-4 3 4 3" />
                    <path d="m16 9 4 3-4 3" />
                    <path d="m14 5-4 14" />
                  </svg>
                )
              }
              {
                icon === "lock" && (
                  <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="4" y="10" width="16" height="10" rx="2" />
                    <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                    <path d="M12 14v2" />
                  </svg>
                )
              }
              {
                icon === "globe" && (
                  <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M3 12h18" />
                    <path d="M12 3a14 14 0 0 1 0 18" />
                    <path d="M12 3a14 14 0 0 0 0 18" />
                  </svg>
                )
              }
              {
                icon === "search" && (
                  <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                    <circle cx="11" cy="11" r="7" />
                    <path d="m20 20-4-4" />
                    <path d="M8 11h6" />
                  </svg>
                )
              }
              {
                icon === "terminal" && (
                  <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="5" width="18" height="14" rx="2" />
                    <path d="m8 10 3 2-3 2" />
                    <path d="M13 15h4" />
                  </svg>
                )
              }
              {
                icon === "bug" && (
                  <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M8 6a4 4 0 0 1 8 0" />
                    <rect x="7" y="8" width="10" height="12" rx="5" />
                    <path d="M3 13h4" />
                    <path d="M17 13h4" />
                    <path d="M4 20l3-3" />
                    <path d="M20 20l-3-3" />
                  </svg>
                )
              }
            </div>
            <h3 class="mt-5 text-base font-black leading-5">{title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">{description}</p>
          </article>
        ))
      }
    </div>

  </div>
</section>
