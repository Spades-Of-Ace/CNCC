---
const steps = [
  {
    title: "Apply Publicly",
    text: "Cyber Arena 2026 opens to all applicants, with every completed entry considered.",
    metric: "300+ candidates",
  },
  {
    title: "Compete Online",
    text: "Participants solve CTF challenges and compete for the top team positions.",
    metric: "75 teams",
  },
  {
    title: "Advance as Top Teams",
    text: "The highest-performing Cyber Arena teams move forward into the national pathway.",
    metric: "12 participants / 3 teams",
  },
  {
    title: "Qualify for CNCC 2026",
    text: "Qualified participants from Cyber Arena enter the Cambodia National Cybersecurity Competition.",
    metric: "120 participants / 30 teams",
  },
  {
    title: "Win Nationally",
    text: "CNCC selects national winners and the best write-up team for the next stage.",
    metric: "16 participants / 4 teams",
  },
  {
    title: "Train Intensively",
    text: "Selected talents continue into an 8-week intensive training program.",
    metric: "Aug 29 - Oct 31",
  },
];
---

<section
  id="roadmap"
  class="relative overflow-hidden bg-[#f7fbff] px-6 py-20 text-[#07143a] sm:px-10 lg:px-16"
>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-white to-transparent"></div>

  <div class="relative mx-auto max-w-[1500px]">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-black uppercase tracking-wide text-[#d97918]">
        Roadmap
      </p>
      <h2 class="mt-3 text-4xl font-black leading-tight sm:text-5xl">
        From Cyber Arena to national recognition
      </h2>
      <p class="mt-4 text-base leading-7 text-slate-600">
        The roadmap explains the participant journey, while the timeline above
        keeps the official dates.
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-6">
      {
        steps.map((step, index) => (
          <article class="relative rounded-lg border border-[#d9e6f7] bg-white p-5 shadow-[0_12px_34px_rgba(7,20,58,0.07)]">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[#06163d] text-lg font-black text-[#f7b733] shadow-lg">
              {index + 1}
            </span>
            <h3 class="mt-5 text-lg font-black leading-6">{step.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">{step.text}</p>
            <p class="mt-5 rounded-md bg-[#0f6bff]/10 px-3 py-2 text-sm font-black text-[#0b54c8]">
              {step.metric}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
