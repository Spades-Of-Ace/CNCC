---
import firstPlace from "../../assets/images/CNCC-1st-Placement-Poster.png";
import secondPlace from "../../assets/images/CNCC-2nd-Placement-Poster.png";
import thirdPlace from "../../assets/images/CNCC-3rd-Placement-Poster.png";
import fourthPlace from "../../assets/images/CNCC-4th-Placement-Poster.png";
import fifthPlace from "../../assets/images/CNCC-5th-Placement-Poster (2).png";

const winners = [
  { title: "1st Place", image: firstPlace },
  { title: "2nd Place", image: secondPlace },
  { title: "3rd Place", image: thirdPlace },
  { title: "4th Place", image: fourthPlace },
  { title: "5th Place", image: fifthPlace },
];
---

<section
  id="spotlight"
  class="relative overflow-hidden bg-[#f7fbff] px-6 py-20 text-[#07143a] sm:px-10 lg:px-16"
>
  <div class="absolute inset-0 opacity-70">
    <div class="absolute left-0 top-20 h-72 w-72 bg-[radial-gradient(circle,rgba(15,107,255,0.11),transparent_65%)]"></div>
    <div class="absolute right-0 bottom-20 h-96 w-96 bg-[radial-gradient(circle,rgba(247,183,51,0.13),transparent_62%)]"></div>
  </div>

  <div class="relative mx-auto max-w-[1500px]">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-black uppercase tracking-wide text-[#d97918]">
        Spotlight
      </p>
      <h2 class="mt-3 text-4xl font-black leading-tight sm:text-5xl">
        Champion Spotlight
      </h2>
      <p class="mt-4 text-base leading-7 text-slate-600">
        Explore the winner posters, then relive the competition through the
        highlight video.
      </p>
    </div>

    <section
      class="mx-auto mt-12 max-w-5xl"
      aria-labelledby="winner-carousel-heading"
      data-winner-carousel
    >
      <div class="mb-6">
        <div>
          <p class="text-sm font-black uppercase tracking-wide text-[#d97918]">
            Winning Poster
          </p>
          <h3 id="winner-carousel-heading" class="mt-2 text-3xl font-black">
            CNCC Winners
          </h3>
        </div>
      </div>

      <div
        class="overflow-hidden rounded-xl border border-[#d9e6f7] bg-white p-4 shadow-[0_18px_50px_rgba(7,20,58,0.12)] sm:p-6"
      >
        <div class="relative mx-auto max-w-md">
          <div class="relative mb-10 aspect-[4/5]">
          {
            winners.map((winner, index) => (
              <figure
                class:list={[
                  "winner-slide",
                  "absolute inset-0 transition-all duration-500 ease-out",
                  index === 0
                    ? "opacity-100 translate-x-0 scale-100"
                    : "pointer-events-none opacity-0 translate-x-4 scale-[0.98]",
                ]}
                data-carousel-slide
              >
                <div class="overflow-hidden rounded-lg bg-[#06163d] shadow-[0_16px_36px_rgba(7,20,58,0.18)]">
                  <img
                    src={winner.image.src}
                    alt={`${winner.title} CNCC winner poster`}
                    class="aspect-[4/5] w-full object-contain"
                  />
                </div>
                <figcaption class="mt-4 text-center text-sm font-black uppercase tracking-wide text-[#0b54c8]">
                  {winner.title}
                </figcaption>
              </figure>
            ))
          }
          </div>

          <button
            type="button"
            class="absolute left-3 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/70 bg-white/90 text-[#0b54c8] shadow-[0_10px_28px_rgba(7,20,58,0.22)] backdrop-blur transition hover:bg-[#0f6bff] hover:text-white sm:-left-6"
            aria-label="Previous winner"
            data-carousel-prev
          >
            <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
          </button>

          <button
            type="button"
            class="absolute right-3 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/70 bg-white/90 text-[#0b54c8] shadow-[0_10px_28px_rgba(7,20,58,0.22)] backdrop-blur transition hover:bg-[#0f6bff] hover:text-white sm:-right-6"
            aria-label="Next winner"
            data-carousel-next
          >
            <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </button>
        </div>

        <div class="mt-7 flex items-center gap-4 overflow-x-auto pb-2">
          {
            winners.map((winner, index) => (
              <button
                type="button"
                class:list={[
                  "winner-thumb shrink-0 rounded-lg border bg-white p-1 shadow-sm transition",
                  index === 0
                    ? "border-[#0f6bff] ring-2 ring-[#0f6bff]/25"
                    : "border-[#d9e6f7] opacity-75 hover:opacity-100",
                ]}
                aria-label={`Show ${winner.title} winner poster`}
                data-carousel-thumb
                data-index={index}
              >
                <img
                  src={winner.image.src}
                  alt=""
                  class="h-24 w-20 rounded-md object-contain sm:h-28 sm:w-24"
                />
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-5xl" aria-labelledby="video-spotlight">
      <div class="mb-6">
        <p class="text-sm font-black uppercase tracking-wide text-[#d97918]">
          Highlight Video
        </p>
        <h3 id="video-spotlight" class="mt-2 text-3xl font-black">
          Relive CNCC 2025
        </h3>
      </div>

      <div
        class="overflow-hidden rounded-xl border border-[#d9e6f7] bg-[#06163d] p-3 shadow-[0_18px_50px_rgba(7,20,58,0.16)]"
      >
        <video
          class="aspect-video w-full rounded-lg object-cover"
          controls
          preload="metadata"
          playsinline
        >
          <source src="/videos/cncc-highlight.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>
    </section>
  </div>
</section>

<script>
  const carousels = document.querySelectorAll("[data-winner-carousel]");

  carousels.forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll("[data-carousel-slide]"));
    const thumbs = Array.from(carousel.querySelectorAll("[data-carousel-thumb]"));
    const prev = carousel.querySelector("[data-carousel-prev]");
    const next = carousel.querySelector("[data-carousel-next]");
    let activeIndex = 0;
    let timer;

    const setActive = (index) => {
      activeIndex = (index + slides.length) % slides.length;

      slides.forEach((slide, slideIndex) => {
        const isActive = slideIndex === activeIndex;
        slide.classList.toggle("pointer-events-none", !isActive);
        slide.classList.toggle("opacity-0", !isActive);
        slide.classList.toggle("translate-x-4", !isActive);
        slide.classList.toggle("scale-[0.98]", !isActive);
        slide.classList.toggle("opacity-100", isActive);
        slide.classList.toggle("translate-x-0", isActive);
        slide.classList.toggle("scale-100", isActive);
        slide.setAttribute("aria-hidden", String(!isActive));
      });

      thumbs.forEach((thumb, thumbIndex) => {
        const isActive = thumbIndex === activeIndex;
        thumb.classList.toggle("border-[#0f6bff]", isActive);
        thumb.classList.toggle("ring-2", isActive);
        thumb.classList.toggle("ring-[#0f6bff]/25", isActive);
        thumb.classList.toggle("border-[#d9e6f7]", !isActive);
        thumb.classList.toggle("opacity-75", !isActive);
      });
    };

    const startTimer = () => {
      window.clearInterval(timer);
      timer = window.setInterval(() => setActive(activeIndex + 1), 5000);
    };

    prev?.addEventListener("click", () => {
      setActive(activeIndex - 1);
      startTimer();
    });

    next?.addEventListener("click", () => {
      setActive(activeIndex + 1);
      startTimer();
    });

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        setActive(Number(thumb.getAttribute("data-index")));
        startTimer();
      });
    });

    setActive(0);
    startTimer();
  });
</script>
