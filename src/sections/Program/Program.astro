---
import programBackground from "../../assets/images/progrram background.png";

const details = [
  ["Duration", "1 Day"],
  ["Format", "Jeopardy (Dynamic Scoring)"],
  ["Team Size", "4 members maximum"],
];
---

<section
  id="program"
  class="relative overflow-hidden bg-[#03143b] px-6 py-20 text-white sm:px-10 lg:px-16"
>
  <img
    src={programBackground.src}
    alt=""
    class="absolute inset-0 h-full w-full object-cover object-center"
  />
  <div
    class="absolute inset-0 bg-[linear-gradient(90deg,rgba(3,20,59,0.96)_0%,rgba(3,20,59,0.78)_46%,rgba(3,20,59,0.18)_100%)]"
  >
  </div>

  <div
    class="relative mx-auto grid max-w-[1500px] gap-12 lg:grid-cols-[1fr_1.05fr] lg:items-center"
  >
    <div>
      <p class="text-sm font-black uppercase tracking-wide text-[#f7b733]">
        Program
      </p>
      <h2 class="mt-3 max-w-xl text-4xl font-black leading-tight sm:text-5xl">
        One day. Real challenge. Limitless opportunity.
      </h2>
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-200">
        Cyber Arena 2026 is part of Cambodia's national CTF roadmap. Top teams
        advance toward Cambodia National Cybersecurity Competition 2026, where
        qualified participants compete for national recognition and the next
        stage of training.
      </p>

      <div class="mt-9 grid gap-5 sm:max-w-2xl sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
        {
          details.map(([label, value]) => (
            <div class="flex items-center gap-4">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-sky-300/35 bg-sky-400/10 text-sky-300">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8">
                  <circle cx="12" cy="12" r="9" />
                  <path d="M12 7v5l3 2" />
                </svg>
              </span>
              <span>
                <span class="block text-sm font-black">{label}</span>
                <span class="mt-1 block text-sm text-slate-300">{value}</span>
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="hidden min-h-[320px] lg:block lg:min-h-[380px]"></div>
  </div>
</section>
