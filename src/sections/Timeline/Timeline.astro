---
const events = [
  {
    title: "Open Registration",
    date: "8th May, 2026",
    meta: "",
    icon: "clipboard",
  },
  {
    title: "Close Application",
    date: "8th June, 2026",
    meta: "",
    icon: "lock",
  },
  {
    title: "Confirmation Email",
    date: "13th June, 2026",
    meta: "",
    icon: "mail",
  },
  {
    title: "1st Orientation",
    date: "20th June, 2026",
    meta: "Online",
    icon: "users",
  },
  {
    title: "Cyber Arena 2026 Competition Day & Top Teams Announcement",
    date: "27th June, 2026",
    meta: "Online",
    icon: "flag",
  },
  {
    title: "2nd Orientation",
    date: "8th August, 2026",
    meta: "On-site",
    icon: "building",
  },
  {
    title: "CNCC Competition Day & National Winners Announcement",
    date: "16th August, 2026",
    meta: "On-site",
    icon: "trophy",
  },
  {
    title: "8-week Intensive Training",
    date: "29th August - 31st October, 2026",
    meta: "Online and/or On-site",
    icon: "graduation",
  },
];
---

<section
  id="timeline"
  class="relative overflow-hidden bg-white px-6 py-20 text-[#07143a] sm:px-10 lg:px-16"
>
  <div class="mx-auto max-w-[1500px]">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-black uppercase tracking-wide text-[#d97918]">
        Program Timeline
      </p>
      <h2 class="mt-3 text-4xl font-black leading-tight sm:text-5xl">
        Key Dates of Cambodia National CTF Roadmap
      </h2>
      <p class="mt-3 text-sm font-bold text-slate-500">
        Subject to changes
      </p>
    </div>

    <div class="mt-12 overflow-x-auto pb-4">
      <div class="relative min-w-[1320px] px-4 pt-8">
        <div
          class="absolute left-12 right-12 top-[66px] h-1 rounded-full bg-gradient-to-r from-[#0f6bff] via-[#f7b733] to-[#0f6bff]"
        >
        </div>

        <div class="grid grid-cols-8 gap-5">
          {
            events.map((event) => (
              <article class="relative text-center">
                <div class="relative mx-auto flex h-20 w-20 items-center justify-center rounded-full border-4 border-white bg-[#06163d] text-[#f7b733] shadow-[0_12px_28px_rgba(7,20,58,0.22)] ring-2 ring-[#0f6bff]/45">
                  {
                    event.icon === "clipboard" && (
                      <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 4h6" />
                        <path d="M9 2h6v4H9z" />
                        <path d="M6 4H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1" />
                        <path d="M8 12h8" />
                        <path d="M8 16h5" />
                      </svg>
                    )
                  }
                  {
                    event.icon === "lock" && (
                      <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="4" y="10" width="16" height="10" rx="2" />
                        <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                      </svg>
                    )
                  }
                  {
                    event.icon === "mail" && (
                      <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="3" y="5" width="18" height="14" rx="2" />
                        <path d="m3 7 9 6 9-6" />
                      </svg>
                    )
                  }
                  {
                    event.icon === "users" && (
                      <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                      </svg>
                    )
                  }
                  {
                    event.icon === "flag" && (
                      <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M5 22V4" />
                        <path d="M5 4h13l-2 5 2 5H5" />
                      </svg>
                    )
                  }
                  {
                    event.icon === "building" && (
                      <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4 22V8l8-5 8 5v14" />
                        <path d="M9 22v-8h6v8" />
                        <path d="M8 10h.01" />
                        <path d="M12 10h.01" />
                        <path d="M16 10h.01" />
                      </svg>
                    )
                  }
                  {
                    event.icon === "trophy" && (
                      <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M8 21h8" />
                        <path d="M12 17v4" />
                        <path d="M7 4h10v5a5 5 0 0 1-10 0V4Z" />
                        <path d="M5 6H3a3 3 0 0 0 3 3h1" />
                        <path d="M19 6h2a3 3 0 0 1-3 3h-1" />
                      </svg>
                    )
                  }
                  {
                    event.icon === "graduation" && (
                      <svg viewBox="0 0 24 24" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="m22 10-10-5-10 5 10 5 10-5Z" />
                        <path d="M6 12v5c3 2 9 2 12 0v-5" />
                      </svg>
                    )
                  }
                </div>

                <div class="mt-5 min-h-[150px] rounded-lg border border-[#d9e6f7] bg-[#f8fbff] px-3 py-4 shadow-sm">
                  {event.meta && (
                    <p class="mb-1 text-xs font-black uppercase tracking-wide text-[#0f6bff]">
                      {event.meta}
                    </p>
                  )}
                  <h3 class="text-sm font-black leading-5 text-[#07143a]">
                    {event.title}
                  </h3>
                  <p class="mt-2 text-sm font-semibold leading-5 text-slate-600">
                    {event.date}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>

    <div
      class="mt-8 grid gap-0 overflow-hidden rounded-lg border border-sky-300/20 bg-[#071f55] text-white shadow-[0_18px_42px_rgba(7,20,58,0.22)] lg:grid-cols-[0.8fr_1fr_1.25fr]"
    >
      <div class="border-b border-white/10 p-6 lg:border-b-0 lg:border-r">
        <p class="text-sm font-black uppercase tracking-wide text-[#f7b733]">
          Remark
        </p>
        <p class="mt-3 leading-7 text-slate-200">
          Each team consists of a maximum of
          <strong class="text-white">4 members</strong>.
        </p>
        <div class="mt-4 inline-flex items-center gap-3 rounded-md bg-white/10 px-4 py-3">
          <span class="text-2xl font-black text-[#f7b733]">x4</span>
          <span class="text-xs font-black uppercase tracking-wide text-slate-200">
            Players
          </span>
        </div>
      </div>

      <div class="border-b border-white/10 p-6 lg:border-b-0 lg:border-r">
        <p class="text-sm font-black uppercase tracking-wide text-[#f7b733]">
          Cyber Arena 2026
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-200">
          <li>
            Estimated number of participants:
            <strong class="text-white">300 participants or 75 teams</strong>
          </li>
          <li>
            Selected Top Teams:
            <strong class="text-white">12 participants or 3 teams</strong>
          </li>
        </ul>
      </div>

      <div class="p-6">
        <p class="text-sm font-black uppercase tracking-wide text-[#f7b733]">
          Cambodia National Cybersecurity Competition 2026
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-200">
          <li>
            Total participants qualified from Cyber Arena:
            <strong class="text-white">120 participants or 30 teams</strong>
          </li>
          <li>
            Selected 3 Winners + 1 Best Write-up:
            <strong class="text-white">16 participants or 4 teams</strong>
          </li>
        </ul>
      </div>
    </div>

    <p class="mx-auto mt-5 max-w-3xl text-center text-xs leading-5 text-slate-500">
      Note: This is a public competition open to all applicants. As every
      completed entry will be considered, we anticipate a high volume of over
      300+ candidates competing.
    </p>
  </div>
</section>
